SEARCHY_SUMMARY_MODEL=qwen2.5:0.5b-instruct
SEARCHY_AI_MODEL=gemma4:e2b
SEARCHY_SUMMARIZER_NUM_CTX=32768
#SEARCHY_SUMMARIZER_NUM_CTX=4096
SEARCHY_DATA_DIR=/searchi_data
SEARCHY_APP_DB_PATH=/searchi_data/app_data/searchy_app.sqlite3
SEARCHY_SOURCE_DB_DIR=/searchi_data/source_dbs
SEARCHY_ALLOWED_SOURCE_ROOT=/Users
SEARCHY_VECTOR_MODEL=sentence-transformers/all-MiniLM-L6-v2
SEARCHY_ENABLE_VECTOR_RETRIEVAL=1
SEARCHY_VECTOR_MIN_SCORE_DEFAULT=0.2
SEARCHY_RERANKER_URL=http://reranker:8010
SEARCHY_RERANKER_TIMEOUT=15
SEARCHY_STATUS_TOKEN=searchi-local-status
SEARCHY_ENABLE_RERANKER=1
SEARCHY_POLL_SECONDS=3
SEARCHY_ENABLE_SUMMARIZER=1
SEARCHY_SUMMARIZER_URL=http://summariser:8020
SEARCHY_SUMMARIZER_TIMEOUT=180.0
SEARCHY_AI_SOURCE_LIMIT=8
SEARCHY_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L4-v2
SEARCHY_RERANKER_BATCH_SIZE=16
OLLAMA_URL=http://host.docker.internal:11434
HF_HOME=/root/.cache/huggingface
